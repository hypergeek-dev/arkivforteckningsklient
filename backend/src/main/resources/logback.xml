<configuration debug="true" scan="true">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%date %-5level %logger.%M %L - %msg%n</pattern>
        </encoder>
	</appender>

	<root level="info">
		<appender-ref ref="CONSOLE" />
	</root>
 </configuration>