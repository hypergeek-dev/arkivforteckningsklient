# Kopiera till .env.production och fyll i riktiga värden.
# .env.production är gitignorerat — commit aldrig riktiga hemligheter.

# PostgreSQL-autentisering
DB_USERNAME=ihpuser
DB_PASSWORD=BYTA_TILL_STARKT_LOSENORD

# Spring Boot-profil — lämna alltid som "production" utanför lokal miljö
ENVIRONMENT=production

# Nätverksinställningar (Docker-distribution)
# Ändra LISTEN_HOST till 127.0.0.1 om en extern nginx hanterar TLS-terminering.
LISTEN_HOST=0.0.0.0
FRONTEND_PORT=80
